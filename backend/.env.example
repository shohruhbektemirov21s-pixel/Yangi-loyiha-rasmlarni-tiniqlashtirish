APP_NAME="ImageClear AI API"
APP_VERSION="0.1.0"
ENV="development"
DEBUG=true

API_V1_PREFIX="/api/v1"
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

DATABASE_URL="sqlite:///./imageclear.db"

STORAGE_ROOT="storage"
UPLOAD_DIR="storage/uploads"
OUTPUT_DIR="storage/outputs"
STORAGE_URL_PREFIX="/storage"

MAX_UPLOAD_SIZE_MB=20
# Kompressiya / video yuklash (MB). Katta videolar uchun oshiring.
COMPRESS_MAX_UPLOAD_MB=20480
ALLOWED_IMAGE_TYPES=["image/jpeg","image/jpg","image/png","image/webp"]

QUEUE_BACKEND="sync"
QUEUE_PRIORITY_ENABLED=true

JWT_SECRET_KEY="change-this-in-production"
JWT_ALGORITHM="HS256"
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
AUTH_PASSWORD_MIN_LENGTH=8

OCR_ENABLED=true
OCR_LANGUAGE="eng"
OCR_TESSERACT_PSM=6
OCR_TESSERACT_OEM=3
OCR_TIMEOUT_SEC=12
OCR_PREPROCESS_ENABLED=true
OCR_FALLBACK_MESSAGE="No readable text could be extracted from the image."

DEFAULT_PLAN_CODE="free"
FREE_DAILY_UPLOAD_LIMIT=10
PREMIUM_DAILY_UPLOAD_LIMIT=250
FREE_PROCESSING_PRIORITY=1
PREMIUM_PROCESSING_PRIORITY=10
FREE_OCR_MODE="standard"
PREMIUM_OCR_MODE="quality"
PREMIUM_UPSCALE_MIN_SHORT_SIDE=1400
PREMIUM_MONTHLY_PRICE_USD=19
PAYMENT_PROVIDER="placeholder"

REAL_ESRGAN_ENABLED=false
REAL_ESRGAN_MODEL_PATH=""
