# Dev: Next (3000) orqali proxy — signup/login ishlashi uchun backend 8000 da yurishi kerak.
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000/api/v1
# Docker / maxsus: ichki FastAPI manzili (faqat next.config rewrites uchun)
# BACKEND_INTERNAL_URL=http://127.0.0.1:8000
# To'g'ridan-to'g'ri brauzerdan 8000: NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
# Katta fayl (video kompress): Next proxy o'rniga to'g'ridan-to'g'ri FastAPI
NEXT_PUBLIC_LARGE_UPLOAD_API_BASE_URL=http://127.0.0.1:8000/api/v1
NEXT_PUBLIC_UPLOAD_ENDPOINT=/images/upload
NEXT_PUBLIC_RESULT_ENDPOINT=/images/{image_id}/result
NEXT_PUBLIC_HISTORY_ENDPOINT=/images/history
NEXT_PUBLIC_HISTORY_DELETE_ENDPOINT=/images/history/{image_id}
NEXT_PUBLIC_AUTH_REGISTER_ENDPOINT=/auth/register
NEXT_PUBLIC_AUTH_LOGIN_ENDPOINT=/auth/login
NEXT_PUBLIC_AUTH_LOGOUT_ENDPOINT=/auth/logout
NEXT_PUBLIC_AUTH_ME_ENDPOINT=/auth/me
NEXT_PUBLIC_BILLING_OVERVIEW_ENDPOINT=/billing/overview
NEXT_PUBLIC_BILLING_SUBSCRIPTION_ENDPOINT=/billing/subscription
NEXT_PUBLIC_ENHANCE_ENDPOINT=/images/enhance
NEXT_PUBLIC_MAX_UPLOAD_MB=20
